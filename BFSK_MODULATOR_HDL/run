if [file exists work] { file delete -force work }
vlib work

vlog -reportprogress 300 -work work FSK_MODULATOR_HARDWARE_MODEL_pkg.sv
vlog -reportprogress 300 -work work cosine.sv
vlog -reportprogress 30 -work work FSK_MODULATOR_HARDWARE_MODEL.sv
vlog -reportprogress 300 -work work FSK_MODULATOR_HARDWARE_MODEL_tb.sv

vsim -gui work.FSK_MODULATOR_HARDWARE_MODEL_tb

add wave sim:/FSK_MODULATOR_HARDWARE_MODEL_tb/clk
add wave sim:/FSK_MODULATOR_HARDWARE_MODEL_tb/reset
add wave sim:/FSK_MODULATOR_HARDWARE_MODEL_tb/modulating_signal
add wave sim:/FSK_MODULATOR_HARDWARE_MODEL_tb/modulated_signal

run -all